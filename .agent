## src/lib/logger.ts

```typescript
type LogLevel = 'info' | 'warn' | 'error';

interface LogPayload {
  level: LogLevel;
  message: string;
  timestamp: string;
  [key: string]: unknown;
}

function log(level: LogLevel, message: string, context?: Record<string, unknown>): void {
  const payload: LogPayload = {
    level,
    message,
    timestamp: new Date().toISOString(),
    ...context,
  };
  console[level](JSON.stringify(payload));
}

export const logger = {
  info:  (message: string, context?: Record<string, unknown>) => log('info', message, context),
  warn:  (message: string, context?: Record<string, unknown>) => log('warn', message, context),
  error: (message: string, context?: Record<string, unknown>) => log('error', message, context),
};
```

---

## src/middleware.ts

Executado em todas as rotas `/api/*`. Responsável por autenticação e logging global.

```typescript
import { NextRequest, NextResponse } from 'next/server';
import { logger } from '@/lib/logger';

export function middleware(request: NextRequest): NextResponse {
  const { method, url, headers } = request;
  const start = Date.now();

  logger.info('Incoming request', {
    method,
    url,
    userAgent: headers.get('user-agent'),
  });

  // Autenticação — valide token/sessão aqui
  const authHeader = headers.get('authorization');
  if (!authHeader) {
    logger.warn('Unauthorized request', { url });
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
  }

  const response = NextResponse.next();

  // Log de resposta via header de duração
  response.headers.set('x-response-time', `${Date.now() - start}ms`);

  return response;
}

export const config = {
  matcher: '/api/:path*',
};
```

---

## API Route — Coleção

```typescript
// src/app/api/v1/[resource]/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { [Resource]Service } from '@/services/[resource].service';
import { adapt[Resource]List } from '@/adapters/[resource].adapter';
import { logger } from '@/lib/logger';
import { HttpError } from '@/lib/http-client';

const service = new [Resource]Service();

export async function GET(request: NextRequest): Promise<NextResponse> {
  const { searchParams } = new URL(request.url);
  const filters = Object.fromEntries(searchParams.entries());

  logger.info('[resource] GET list request received', { filters });

  try {
    const backendData = await service.getAll(filters);
    const adapted    = adapt[Resource]List(backendData);

    logger.info('[resource] GET list completed', { total: adapted.length });

    return NextResponse.json(adapted);
  } catch (error) {
    return handleError(error, '[resource] GET list failed');
  }
}

export async function POST(request: NextRequest): Promise<NextResponse> {
  const body = await request.json();

  logger.info('[resource] POST request received', { payload: body });

  try {
    const created = await service.create(body);
    const adapted = adapt[Resource](created);

    logger.info('[resource] POST completed', { id: adapted.id });

    return NextResponse.json(adapted, { status: 201 });
  } catch (error) {
    return handleError(error, '[resource] POST failed');
  }
}

function handleError(error: unknown, context: string): NextResponse {
  if (error instanceof HttpError) {
    logger.warn(context, { status: error.status, url: error.url });
    return NextResponse.json({ error: error.body }, { status: error.status });
  }

  logger.error(context, { error: String(error) });
  return NextResponse.json({ error: 'Internal server error' }, { status: 500 });
}
```

---

## API Route — Por ID

```typescript
// src/app/api/v1/[resource]/[id]/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { [Resource]Service } from '@/services/[resource].service';
import { adapt[Resource] } from '@/adapters/[resource].adapter';
import { logger } from '@/lib/logger';
import { HttpError } from '@/lib/http-client';

const service = new [Resource]Service();

export async function GET(
  _request: NextRequest,
  { params }: { params: { id: string } },
): Promise<NextResponse> {
  const { id } = params;

  logger.info('[resource] GET by id request received', { id });

  try {
    const data    = await service.getById(id);
    const adapted = adapt[Resource](data);

    logger.info('[resource] GET by id completed', { id });

    return NextResponse.json(adapted);
  } catch (error) {
    return handleError(error, '[resource] GET by id failed', id);
  }
}

function handleError(error: unknown, context: string, id?: string): NextResponse {
  if (error instanceof HttpError) {
    logger.warn(context, { status: error.status, id });
    return NextResponse.json({ error: error.body }, { status: error.status });
  }

  logger.error(context, { error: String(error), id });
  return NextResponse.json({ error: 'Internal server error' }, { status: 500 });
}
```

---

## Service — chamada ao backend

```typescript
// src/services/[resource].service.ts
import { httpGet, httpPost } from '@/lib/http-client';

const BASE_URL = process.env.BACKEND_[RESOURCE]_URL!;

export interface [Resource]BackendResponse {
  id:     string;
  name:   string;
  status: string;
  // campos como chegam do backend
}

export class [Resource]Service {
  async getAll(filters?: Record<string, string>): Promise<[Resource]BackendResponse[]> {
    return httpGet<[Resource]BackendResponse[]>(`${BASE_URL}/api/v1/[resources]`, { params: filters });
  }

  async getById(id: string): Promise<[Resource]BackendResponse> {
    return httpGet<[Resource]BackendResponse>(`${BASE_URL}/api/v1/[resources]/${id}`);
  }

  async create(body: unknown): Promise<[Resource]BackendResponse> {
    return httpPost<[Resource]BackendResponse>(`${BASE_URL}/api/v1/[resources]`, body);
  }
}
```

---

## Adapter — transformação para o frontend

```typescript
// src/adapters/[resource].adapter.ts
import type { [Resource]BackendResponse } from '@/services/[resource].service';

export interface [Resource]FrontendModel {
  id:          string;
  displayName: string;
  isActive:    boolean;
  // formato que o frontend consome
}

export function adapt[Resource](data: [Resource]BackendResponse): [Resource]FrontendModel {
  return {
    id:          data.id,
    displayName: data.name,
    isActive:    data.status === 'ACTIVE',
  };
}

export function adapt[Resource]List(data: [Resource]BackendResponse[]): [Resource]FrontendModel[] {
  return data.map(adapt[Resource]);
}
```

---

## Swagger

Todo BFF deve expor documentação Swagger. Instale as dependências:

```bash
npm install swagger-ui-react openapi-types
npm install --save-dev @types/swagger-ui-react
```

> **`openapi-types` é obrigatório** como dependência de produção (não `devDependency`) pois é importado em `src/lib/openapi.ts` que é compilado no build.

Crie a spec OpenAPI em `src/lib/openapi.ts` e os dois pontos de acesso:

```typescript
// src/app/api/docs/route.ts — retorna a spec como JSON
import { NextResponse } from 'next/server';
import { openApiSpec } from '@/lib/openapi';

export async function GET(): Promise<NextResponse> {
  return NextResponse.json(openApiSpec);
}
```

```typescript
// src/app/docs/page.tsx — UI do Swagger
'use client';
import SwaggerUI from 'swagger-ui-react';
import 'swagger-ui-react/swagger-ui.css';

export default function DocsPage() {
  return <SwaggerUI url="/api/docs" persistAuthorization displayRequestDuration tryItOutEnabled />;
}
```

```typescript
// src/app/layout.tsx — root layout obrigatório pelo Next.js App Router
export const metadata = {
  title: '[NomeDoBFF]',
};

export default function RootLayout({ children }: { children: React.ReactNode }) {
  return (
    <html lang="en">
      <body>{children}</body>
    </html>
  );
}
```

> **Root layout obrigatório:** O Next.js App Router exige um `src/app/layout.tsx` sempre que houver qualquer `page.tsx` no projeto — incluindo a página `/docs`. Sem ele o build falha com `doesn't have a root layout`.

Adicione `/docs` e `/api/docs` nas rotas públicas do middleware. Swagger disponível em `http://localhost:[PORT]/docs`.

---

## Health Endpoint

Todo BFF deve expor um endpoint de health em `src/app/api/health/route.ts`:

```typescript
import { NextResponse } from 'next/server';

export async function GET(): Promise<NextResponse> {
  return NextResponse.json(
    {
      status:    'healthy',
      service:   '[NomeDoBFF]',
      timestamp: new Date().toISOString(),
    },
    { status: 200 },
  );
}
```

> A rota `/api/health` deve ser incluída nas rotas públicas do middleware — não requer autenticação.

